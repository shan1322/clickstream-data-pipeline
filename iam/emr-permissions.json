{
    "Version": "2012-10-17",
    "Statement": [{
        "Effect": "Allow",
        "Action": [
            "s3:GetObject",
            "s3:PutObject",
            "s3:ListBucket",
            "es:ESHttpPost",
            "es:ESHttpPut",
            "redshift:GetClusterCredentials",
            "kafka:DescribeCluster",
            "kafka:GetBootstrapBrokers"
        ],
        "Resource": "*"
    }]
}
